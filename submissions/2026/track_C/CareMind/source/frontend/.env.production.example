EXPO_PUBLIC_CAREMIND_API_URL=https://your-caremind-api.example.com

# iOS / Android release builds both require a deployed HTTPS backend.
# iPhone currently uses the cloud Agent workflow; Android can additionally
# use the on-device Gemma LiteRT privacy mode when a model is downloaded.

# On-device LLM output format. Smaller models (Gemma 1B–4B) are noticeably
# more reliable with XML-style tag output than with strict JSON syntax.
# Leave unset (defaults to xml) on most builds; set to "json" only to
# force the legacy JSON path for A/B comparison or rollback.
# EXPO_PUBLIC_LOCAL_OUTPUT_FORMAT=xml
